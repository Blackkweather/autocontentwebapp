# Copy to .env in this directory (automation/snob_beach_reels/.env) — auto-loaded via
# python-dotenv if installed, otherwise export these in your shell instead.

# Which Step-1 image-expansion backend to use. Defaults to "replicate". Set to "none" to skip
# AI calls entirely and use the offline crop/color-grade fallback (see providers.py).
SNOB_BEACH_IMAGE_PROVIDER=replicate

# Replicate — google/nano-banana, ~$0.03-0.04/image. Same account/token as the main app's
# REPLICATE_API_TOKEN (../../.env.example) if you already have one.
REPLICATE_API_TOKEN=

# OpenAI — gpt-image-1 edits. Alternative to Replicate; set SNOB_BEACH_IMAGE_PROVIDER=openai.
OPENAI_API_KEY=

# Not wired up yet — see the adapter skeletons + doc links in providers.py before enabling.
RUNWAY_API_KEY=
LEONARDO_API_KEY=
HIGGSFIELD_API_KEY=
