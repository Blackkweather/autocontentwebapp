# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — unanchored: npm workspaces can put node_modules at repo root and/or nested
# inside apps/*, modules/*, packages/* depending on hoisting
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js
.next/
out/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# binary assets fetched at build time by apps/dashboard/scripts/fetch-assets.mjs — keeps the
# repo small
apps/dashboard/assets/fonts/*.ttf
apps/dashboard/assets/models/*.onnx

# scratch scripts used only to prep a one-off Vercel file-tree deploy
apps/dashboard/scripts/build-deploy-payload.mjs

# Claude Code local permission settings — has captured literal Bash commands (including
# API keys passed inline on curl command lines) in its allow-list. Never commit.
.claude/settings.local.json
