# Gates the entire app (admin page + every /api/* route) via HTTP Basic Auth — see
# src/proxy.ts. The app returns 503 for every request unless at least one login is configured,
# via either mechanism below (they can be combined).
#
# Single admin:
ADMIN_USER=
ADMIN_PASSWORD=
#
# Multiple admins — one or more "user:password" pairs, comma- or newline-separated. Every login
# has the same full access. NOTE: passwords must not contain ':' or ',', and (because this is a
# .env value) avoid '#', which .env parsers treat as a comment. e.g.:
#   ADMIN_USERS=ilyas:Ilyas7K2q,soufiane:Soufi9M4t
ADMIN_USERS=

# Supabase — database, storage (posters + artist-photos buckets), see
# packages/core/src/database/supabase.ts
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: bypasses RLS. Server-side only — every API route uses this, never the
# anon client. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Groq — event copy generation, artist account disambiguation, AND photo screening (via Llama 4
# Scout's vision support) — see packages/core/src/ai/groq.ts. Copy generation alone is optional
# (falls back to deterministic copy if unset), but this is REQUIRED for the auto-sourcing
# pipeline: without it, no Deezer/SocialCrawl/Google/Brave candidate photo can ever pass identity
# verification, and every event falls through to photo_missing regardless of whether a good photo
# was found. Free tier (1,000 req/day) comfortably covers this app's volume. Manual photo library
# uploads still work without it.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Deezer artist search — photo sourcing tier 3 (packages/core/src/search/deezerImageSearch.ts).
# No API key, no signup, no config needed — public endpoint, works out of the box.

# SocialCrawl — Instagram photo sourcing, tier 4 (packages/core/src/search/socialcrawl.ts). Optional.
SOCIALCRAWL_API_KEY=
SOCIALCRAWL_BASE_URL=https://www.socialcrawl.dev

# Google Programmable Search (Image mode) — photo sourcing tier 5
# (packages/core/src/search/googleImageSearch.ts). Optional.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Brave Search API (Image mode) — photo sourcing tier 6 (packages/core/src/search/braveImageSearch.ts). Optional.
BRAVE_API_KEY=

# Replicate — background-removal fallback when the local ONNX model fails, AND the "AI Scene
# Brief" feature (packages/core/src/ai/replicate.ts's generateSceneImage, via Google Nano Banana /
# Gemini 2.5 Flash Image) that lets a per-event free-text prompt ("Lacrim in GTA 6, 4K showcase")
# generate a custom scene from the artist's real sourced photo — or fuse up to 3 real artist
# photos into one lineup scene when "other artists" is also filled in (e.g. a themed group flyer).
# Optional overall — without it, background removal falls back to the local ONNX model and the AI
# Scene Brief field just fails with a clear error if used. Unlike every other integration in this
# app, this one is NOT free: roughly $0.03-0.04 per image generated, billed to your Replicate account.
REPLICATE_API_TOKEN=

# Sentry — error tracking for failed generations (packages/core/src/observability/errorTracking.ts).
# Optional: failures are always logged to console (visible in Vercel's Runtime Logs regardless),
# but nothing pages a human until this is set. Create a free project at sentry.io and paste its DSN here.
SENTRY_DSN=
