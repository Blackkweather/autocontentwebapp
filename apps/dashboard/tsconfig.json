{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // baseUrl is required for Next's webpack path-alias plugin (JsConfigPathsPlugin) to
    // register "@/*" at bundle time. TypeScript's bundler resolution tolerates its absence
    // (so type-check and some environments pass), but the Vercel production build fails with
    // "Module not found: Can't resolve '@/lib/...'" without it. Keep it explicit.
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    // Ambient module declaration for onnxruntime-node, transitively pulled in via
    // @club-os/flyer-engine -> @club-os/core/media/bgremove — TS needs it in-program.
    "../../packages/core/src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
